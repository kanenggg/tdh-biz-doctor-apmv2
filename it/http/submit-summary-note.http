### Submit summary note - Success case

POST {{ HOST }}/internal/v1/summary-note HTTP/1.1
Content-Type: application/json
Tdh-Sec-Iam-User-Identity: {"accountId":3001,"accountType":1,"userProfileId":4001,"userMainProfileId":789,"tenantId":1,"oidcUserId":"test-user"}

{
  "bookingId": "10021",
  "prescriptionId": null,
  "presentIllness": "Patient has fever and cough",
  "chiefComplaint": "Fever for 3 days",
  "diagnosis": "Upper respiratory infection",
  "recommendations": "Rest and drink plenty of fluids",
  "icd10": [
    {
      "code": "J00",
      "description": "Acute nasopharyngitis"
    },
    {
      "code": "R50",
      "description": "Fever"
    }
  ],
  "illnessDuration": {
    "value": 3,
    "unit": "days"
  },
  "noteToStaff": "Patient allergic to penicillin",
  "followUp": {
    "__type": "AsNeeded"
  }
}

