### Submit summary note - With prescription ID

POST {{ HOST }}/e2e/v1/summary-note HTTP/1.1
Content-Type: application/json
Tdh-Sec-Iam-User-Identity: {"accountId":3001,"accountType":1,"userProfileId":4001,"userMainProfileId":789,"tenantId":1,"oidcUserId":"test-user"}

{
  "bookingId": "10023",
  "prescriptionId": 12345,
  "presentIllness": "Patient complains of back pain",
  "chiefComplaint": "Lower back pain",
  "diagnosis": "Muscle strain",
  "recommendations": "Physical therapy and rest",
  "icd10": [
    {
      "code": "M54.5",
      "description": "Low back pain"
    }
  ],
  "illnessDuration": {
    "value": 7,
    "unit": "days"
  },
  "noteToStaff": "Follow up in 2 weeks"
}

