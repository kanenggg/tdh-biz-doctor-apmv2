# Consultation-RS Environment Variables
# Copy this file to .env and update with your actual values
# Note: Variables must have APP__ prefix for config crate to pick them up
# This file is automatically loaded by dotenv on service startup

# Server Configuration
APP__SERVER__HOST=0.0.0.0
APP__SERVER__PORT=8080

# Database Configuration
APP__DATABASE__USER=postgres_user
APP__DATABASE__PASSWORD=your_password
APP__DATABASE__HOST=localhost
APP__DATABASE__PORT=5432
APP__DATABASE__DATABASE_NAME=consultation

# Session Configuration
APP__SESSION__LEAD_TIME_SECONDS=300
APP__SESSION__CONSULTATION_DURATION_MINUTES=30
APP__SESSION__REQUIRED_APPOINTMENT_STATUS=CONFIRMED
APP__SESSION__SKIP_CHAT_BIZ_UNIT_ID=2

# Twilio Configuration
APP__TWILIO__BASE_URL=http://localhost
APP__TWILIO__VIDEO_BASE_URL=https://video.twilio.com
APP__TWILIO__CHAT_BASE_URL=https://conversations.twilio.com
APP__TWILIO__ACCOUNT_SID=ACXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
APP__TWILIO__API_KEY_SID=SKXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
APP__TWILIO__API_KEY_SECRET=your_api_key_secret
APP__TWILIO__AUTH_TOKEN=your_auth_token
APP__TWILIO__CALLBACK_URL=http://localhost/twilio/callback

# Video Provider Configuration
APP__VIDEO__PROVIDER_TYPE=twilio

# Google Cloud Configuration (for production)
# Leave these empty to use local alternatives
APP__BOOKING__KMS_KEY_NAME=
APP__BOOKING__PUBSUB_PROJECT_ID=
APP__BOOKING__PUBSUB_TOPIC=
APP__BOOKING__PUBSUB_EMULATOR_HOST=

# Local Encryption (used when KMS_KEY_NAME is empty)
# Generate a 64-character hex string for AES-256-GCM encryption
APP__BOOKING__LOCAL_KMS_KEY_HEX=01234567890abcdef01234567890abcdef01234567890abcdef01234567890ab

# Logging
RUST_LOG=info,consultation_rs=debug

# Authentication Header
# The service expects a header: tdh-sec-iam-user-identity
# This header should contain a JSON string with UserIdentity data
# Example value: {"accountId":123,"accountType":888,"userProfileId":456,"tenantId":1,"oidcUserId":"user123"}
